generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress  Progress[]
}

model Module {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  slug      String     @unique
  icon      String
  color     String
  order     Int        @default(0)
  createdAt DateTime   @default(now())

  questions Question[]
  progress  Progress[]
}

model Question {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  question      String
  answer        String
  explanation   String?
  questionMn    String?
  answerMn      String?
  explanationMn String?
  order         Int     @default(0)

  moduleId String @db.ObjectId
  module   Module @relation(fields: [moduleId], references: [id])
}

model Progress {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  completed Int      @default(0)
  total     Int      @default(0)
  updatedAt DateTime @updatedAt

  userId   String @db.ObjectId
  user     User   @relation(fields: [userId], references: [id])

  moduleId String @db.ObjectId
  module   Module @relation(fields: [moduleId], references: [id])

  @@unique([userId, moduleId])
}
